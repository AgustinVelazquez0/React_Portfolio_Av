PORT=5050
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Comma-separated allowed origins (recommended for production)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================================
# Ask my CV agent (Tier 3) — provider AI
# ============================================================
# AI_PROVIDER: groq (free) | openai (paid). Auto-detects if empty.
AI_PROVIDER=groq

# Groq — free tier, ultra-fast (https://console.groq.com/keys)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — paid fallback
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
